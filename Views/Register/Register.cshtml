@{
    ViewData["Title"] = "Register";
}

<style>
    :root {
        --palette-dark-slate: #2F3E46;
        --palette-teal: #14B8A6;
        --palette-teal-hover: #0D9488;
        --palette-white: #FFFFFF;
    }

    /* Fixed top navbar buffer so the form doesn't overlap */
    .register-container-wrapper {
        min-height: calc(100vh - 100px);
        margin-top: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 15px;
    }

    .register-wrapper {
        width: 100%;
        max-width: 480px;
        z-index: 1;
    }

    /* Main Registration Card using the Teal Palette */
    .register-card {
        background-color: var(--palette-teal);
        border: none;
        border-radius: 12px;
        box-shadow: 0 8px 24px rgba(20, 184, 166, 0.25);
        color: var(--palette-white);
    }

        .register-card .card-header {
            background: transparent;
            border-bottom: 1px solid rgba(255, 255, 255, 0.2);
            text-align: center;
            padding: 1.5rem 1rem 1rem 1rem;
        }

        .register-card .form-control {
            background-color: rgba(255, 255, 255, 0.9);
            border: 1px solid transparent;
            color: #333;
        }

            .register-card .form-control:focus {
                background-color: var(--palette-white);
                box-shadow: 0 0 0 0.25rem rgba(47, 62, 70, 0.25);
                border-color: var(--palette-dark-slate);
            }

    /* Submit Button matching the Dark Slate */
    .btn-submit {
        background-color: var(--palette-dark-slate);
        color: var(--palette-white);
        border: none;
        transition: all 0.2s ease-in-out;
        font-weight: 600;
    }

        .btn-submit:hover {
            background-color: #222d33;
            color: var(--palette-white);
            transform: translateY(-1px);
        }

    .register-card a {
        color: rgba(255, 255, 255, 0.85);
        text-decoration: none;
    }

        .register-card a:hover {
            color: var(--palette-white);
            text-decoration: underline;
        }
</style>

<div class="register-container-wrapper">
    <div class="register-wrapper">
        <div class="card register-card p-4">
            <div class="card-header">
                <h3 class="fw-bold m-0">Create Account</h3>
                <small class="text-white-50">Join us by filling out the details below.</small>
            </div>
            <div class="card-body pt-4">
                <form id="registerForm" method="post" asp-action="Register" asp-controller="Account">

                    <div class="row">
                        <div class="col-md-6 mb-3">
                            <label for="firstName" class="form-label small fw-semibold">First Name</label>
                            <input type="text" class="form-control" id="firstName" name="FirstName" placeholder="John" required />
                        </div>
                        <div class="col-md-6 mb-3">
                            <label for="lastName" class="form-label small fw-semibold">Last Name</label>
                            <input type="text" class="form-control" id="lastName" name="LastName" placeholder="Doe" required />
                        </div>
                    </div>

                    <div class="mb-3">
                        <label for="email" class="form-label small fw-semibold">Email Address</label>
                        <input type="email" class="form-control" id="email" name="Email" placeholder="name@example.com" required />
                    </div>

                    <div class="mb-3">
                        <label for="password" class="form-label small fw-semibold">Password</label>
                        <input type="password" class="form-control" id="password" name="Password" placeholder="Create password" required />
                    </div>

                    <div class="mb-4">
                        <label for="confirmPassword" class="form-label small fw-semibold">Confirm Password</label>
                        <input type="password" class="form-control" id="confirmPassword" name="ConfirmPassword" placeholder="Repeat password" required />
                    </div>

                    <button type="submit" class="btn btn-submit btn-lg w-100 py-2.5 shadow-sm mb-3">Register</button>

                    <div class="text-center">
                        <span class="small text-white-50">Already have an account?</span>
                        <a asp-action="Login" asp-controller="Login" class="small fw-semibold ms-1">Sign In</a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>


                    @section Scripts {
    <script>
        $(document).ready(function () {
            $('#registerForm').on('submit', function (e) {
                // Prevent the form from submitting and reloading the page
                e.preventDefault();

                // Grab values using jQuery
              
                var firstName = $('#firstName').val();
                var lastName = $('#lastName').val();
                var username = $('#username').val();
                var password = $('#password').val();
                var confirmpassword = $('#confirmPassword').val();

                // Fire the simple native browser alert
                alert(
                    "Credentials Captured!\n\n" +
                    "Fullname: " + firstName + lastName + " \n" +
                    "Username: " + username + "\n" +
                    "Password: " + password + "\n" +
                    "Confirm Password: " + confirmpassword
                );

                // No submit call here! The page will not refresh.
            });
        });
    </script>
}